@using FitAI.Application.Features.WorkoutSessionDetail

<MudPaper Elevation="1"
          Class="workout-card pa-4 mb-4">

    <div class="d-flex justify-space-between align-start mb-2">
        <div>
            <MudText Typo="Typo.h6">
                @Exercise.ExerciseName
            </MudText>

            <MudText Typo="Typo.body2"
                     Color="Color.Secondary">
                @BuildExerciseDescription()
            </MudText>
        </div>

        @if (Exercise.IsCompleted)
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Color="Color.Success"
                     Variant="Variant.Filled">
                Completed
            </MudChip>
        }
        else
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Color="Color.Default"
                     Variant="Variant.Outlined">
                In progress
            </MudChip>
        }
    </div>

    <MudDivider Class="mb-3" />

    <div class="set-grid set-grid-header">
        <div>SET</div>
        <div>PREVIOUS</div>
        <div>KG</div>
        <div>REPS</div>
        <div>RPE</div>
        <div></div>
    </div>

    @foreach (var set in Exercise.Sets.OrderBy(x => x.SetNumber))
    {
        <WorkoutSetRow Set="set"
                       PreviousText="@GetPreviousText(set)"
                       CanDelete="@CanDeleteSet(set)"
                       OnSave="CompleteSetAsync"
                       OnDelete="DeleteSetAsync"
                       OnSetTypeChanged="SetTypeChangedAsync" />
    }

    <div class="d-flex justify-space-between align-center mt-3">
        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddSetAsync">
            Add Set
        </MudButton>

        <MudText Typo="Typo.caption"
                 Color="Color.Secondary">
            Rest @Exercise.TargetRestSeconds sec
        </MudText>
    </div>

</MudPaper>

@code {
    [Parameter, EditorRequired]
    public WorkoutExerciseDto Exercise { get; set; } = default!;

    [Parameter]
    public EventCallback<WorkoutSetDto> OnCompleteSet { get; set; }

    [Parameter]
    public EventCallback<Guid> OnAddSet { get; set; }
    [Parameter]
    public EventCallback<WorkoutSetDto> OnDeleteSet { get; set; }

    [Parameter]
    public EventCallback<WorkoutSetDto> OnSetTypeChanged { get; set; }

    private bool _isSaving;

    private async Task CompleteSetAsync(WorkoutSetDto set)
    {
        if (set.IsCompleted || _isSaving)
        {
            return;
        }

        if (!set.ActualWeightKg.HasValue)
        {
            return;
        }

        if (!set.ActualReps.HasValue || set.ActualReps <= 0)
        {
            return;
        }

        try
        {
            _isSaving = true;

            set.ActualRestSeconds ??=
                set.TargetRestSeconds
                ?? Exercise.TargetRestSeconds;

            await OnCompleteSet.InvokeAsync(set);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task AddSetAsync()
    {
        if (OnAddSet.HasDelegate)
        {
            await OnAddSet.InvokeAsync(Exercise.WorkoutSessionExerciseId);
        }
    }

    private string BuildExerciseDescription()
    {
        var targetSets = Exercise.TargetSets?.ToString() ?? "-";
        var minReps = Exercise.TargetMinReps?.ToString() ?? "-";
        var maxReps = Exercise.TargetMaxReps?.ToString() ?? "-";
        var rest = Exercise.TargetRestSeconds?.ToString() ?? "-";

        return $"{targetSets} sets · {minReps}-{maxReps} reps · Rest {rest} sec";
    }

    private static string GetPreviousText(WorkoutSetDto set)
    {
        if (set.PreviousWeightKg.HasValue
            && set.PreviousReps.HasValue)
        {
            return
                $"{set.PreviousWeightKg.Value:0.##} × " +
                $"{set.PreviousReps.Value}";
        }

        if (set.PreviousReps.HasValue)
        {
            return $"{set.PreviousReps.Value} reps";
        }

        return "-";
    }

    private bool CanDeleteSet(WorkoutSetDto set)
    {
        if (set.IsCompleted || Exercise.Sets.Count <= 1)
        {
            return false;
        }

        return set.SetNumber
            == Exercise.Sets.Max(x => x.SetNumber);
    }

    private Task DeleteSetAsync(WorkoutSetDto set)
    {
        return OnDeleteSet.InvokeAsync(set);
    }

    private Task SetTypeChangedAsync(WorkoutSetDto set)
    {
        return OnSetTypeChanged.InvokeAsync(set);
    }

}