@page "/workout/session/{WorkoutSessionId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer

@using FitAI.Application.Features.WorkoutSets
@inject IWorkoutSetService WorkoutSetService
@using FitAI.Application.Features.WorkoutSessions

@inject ICompleteWorkoutService CompleteWorkoutService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using FitAI.Application.Features.WorkoutSessionDetail
@inject IWorkoutSessionDetailQueryService SessionQueryService

<PageTitle>Workout Session</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large"
              Class="py-4">

    @if (_isLoading)
    {
        <div class="d-flex justify-center py-8">
            <MudProgressCircular Indeterminate="true"
                                 Color="Color.Primary" />
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error"
                  Variant="Variant.Filled">
            @_errorMessage
        </MudAlert>
    }
    else if (_session is null)
    {
        <MudAlert Severity="Severity.Warning">
            Workout session not found.
        </MudAlert>
    }
    else if (string.Equals(
        _session.Status,
        "Completed",
        StringComparison.OrdinalIgnoreCase))
    {
        <MudAlert Severity="Severity.Success"
                  Variant="Variant.Filled"
                  Class="mb-4">
            Workout นี้เสร็จเรียบร้อยแล้ว
        </MudAlert>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="GoToSummary">
            View Workout Summary
        </MudButton>
    }
    else
    {
        <WorkoutHeader SessionName="@_session.SessionName"
                       SessionDate="@_session.SessionDate"
                       StartTime="@_session.StartTime"
                       ExerciseCount="@_session.Exercises.Count" />

        <WorkoutProgress TotalSets="@_totalSets"
                         CompletedSets="@_completedSets"
                         ProgressPercent="@_progressPercent" />

        @foreach (var exercise in _session.Exercises)
        {
            <WorkoutExerciseCard Exercise="exercise"
                                 OnCompleteSet="HandleSetCompletedAsync"
                                 OnAddSet="HandleAddSetAsync"
                                 OnDeleteSet="HandleDeleteSetAsync"
                                 OnSetTypeChanged="HandleSetTypeChangedAsync" />
        }

        <WorkoutFinishPanel TotalSets="@_totalSets"
                            CompletedSets="@_completedSets"
                            TotalVolume="@CalculateCurrentVolume()"
                            IsCompleting="@_isCompletingWorkout"
                            OnFinish="CompleteWorkoutAsync" />
    }

</MudContainer>

@code {
    [Parameter]
    public Guid WorkoutSessionId { get; set; }
    private bool _isCompletingWorkout;
    private bool _isLoading = true;
    private string? _errorMessage;
    private WorkoutSessionDetailDto? _session;

    private int _totalSets;
    private int _completedSets;
    private double _progressPercent;

    protected override async Task OnParametersSetAsync()
    {
        if (WorkoutSessionId == Guid.Empty)
        {
            _session = null;
            _errorMessage = "Workout session ID ไม่ถูกต้อง";
            _isLoading = false;
            return;
        }

        await LoadSessionAsync();
    }

    private async Task LoadSessionAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _session = null;

            var session = await SessionQueryService.GetAsync(
                WorkoutSessionId);

            if (session is null)
            {
                return;
            }

            _session = session;
            CalculateProgress();
        }
        catch (Exception ex)
        {
            _session = null;
            _errorMessage = ex.ToString();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSetCompletedAsync(
        WorkoutSetDto set)
    {
        if (_session is null)
        {
            return;
        }

        if (!set.ActualWeightKg.HasValue
            || !set.ActualReps.HasValue)
        {
            Snackbar.Add(
                "กรุณากรอกน้ำหนักและจำนวนครั้ง",
                Severity.Warning);

            return;
        }

        try
        {
            var result =
                await WorkoutSetService.CompleteSetAsync(
                    new CompleteWorkoutSetCommand
                    {
                        WorkoutSetId = set.Id,
                        ActualWeightKg =
                            set.ActualWeightKg.Value,
                        ActualReps =
                            set.ActualReps.Value,
                        Rpe = set.Rpe,
                        ActualRestSeconds =
                            set.ActualRestSeconds
                            ?? set.TargetRestSeconds
                    });

            set.IsCompleted = true;

            var exercise = _session.Exercises
                .FirstOrDefault(
                    x => x.WorkoutSessionExerciseId
                        == result.WorkoutSessionExerciseId);

            if (exercise is not null)
            {
                exercise.IsCompleted =
                    result.IsExerciseCompleted;
            }

            CalculateProgress();

            Snackbar.Add(
                result.IsExerciseCompleted
                    ? "บันทึกเซ็ตแล้ว และท่านี้เสร็จครบทุกเซ็ต"
                    : "บันทึกเซ็ตเรียบร้อย",
                Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"บันทึกไม่สำเร็จ: {ex.Message}",
                Severity.Error);
        }
    }

    private async Task CompleteWorkoutAsync()
    {
        if (_session is null || _isCompletingWorkout)
        {
            return;
        }

        if (_completedSets == 0)
        {
            Snackbar.Add(
                "ยังไม่มีเซ็ตที่บันทึก กรุณาทำอย่างน้อย 1 เซ็ตก่อนจบการฝึก",
                Severity.Warning);

            return;
        }

        try
        {
            _isCompletingWorkout = true;

            var result = await CompleteWorkoutService.CompleteAsync(
                new CompleteWorkoutCommand
                {
                    WorkoutSessionId = WorkoutSessionId
                });

            Snackbar.Add(
                $"Workout completed: {result.CompletedSets}/{result.TotalSets} sets, " +
                $"Volume {result.TotalVolume:N0} kg, " +
                $"Duration {result.DurationMinutes} min",
                Severity.Success);

            NavigationManager.NavigateTo(
                $"/workout/summary/{result.WorkoutSessionId}");
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"ไม่สามารถจบ Workout ได้: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _isCompletingWorkout = false;
        }
    }

    private async Task HandleAddSetAsync(
        Guid workoutSessionExerciseId)
    {
        if (_session is null)
        {
            return;
        }

        try
        {
            var result = await WorkoutSetService.AddSetAsync(
                new AddWorkoutSetCommand
                {
                    WorkoutSessionExerciseId =
                        workoutSessionExerciseId
                });

            var exercise = _session.Exercises
                .FirstOrDefault(x =>
                    x.WorkoutSessionExerciseId
                        == workoutSessionExerciseId);

            if (exercise is null)
            {
                return;
            }

            exercise.Sets.Add(new WorkoutSetDto
            {
                Id = result.Id,
                SetNumber = result.SetNumber,
                TargetReps = result.TargetReps,
                TargetRestSeconds = result.TargetRestSeconds,
                SetType = result.SetType,
                IsWarmup = false,
                IsCompleted = false,
                IsSkipped = false
            });

            exercise.TargetSets = exercise.Sets.Count;

            CalculateProgress();

            Snackbar.Add(
                $"เพิ่ม Set {result.SetNumber} แล้ว",
                Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"เพิ่ม Set ไม่สำเร็จ: {ex.Message}",
                Severity.Error);
        }
    }
    private async Task HandleDeleteSetAsync(
    WorkoutSetDto set)
    {
        if (_session is null)
        {
            return;
        }

        try
        {
            await WorkoutSetService.DeleteSetAsync(
                new DeleteWorkoutSetCommand
                {
                    WorkoutSetId = set.Id
                });

            var exercise = _session.Exercises
                .FirstOrDefault(x =>
                    x.Sets.Any(s => s.Id == set.Id));

            if (exercise is null)
            {
                return;
            }

            exercise.Sets.Remove(set);
            exercise.TargetSets = exercise.Sets.Count;

            CalculateProgress();

            Snackbar.Add(
                "ลบ Set เรียบร้อย",
                Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"ลบ Set ไม่สำเร็จ: {ex.Message}",
                Severity.Error);
        }
    }
    private async Task HandleSetTypeChangedAsync(
    WorkoutSetDto set)
    {
        try
        {
            await WorkoutSetService.SetWarmupAsync(
                new SetWorkoutSetTypeCommand
                {
                    WorkoutSetId = set.Id,
                    IsWarmup = set.IsWarmup
                });

            Snackbar.Add(
                set.IsWarmup
                    ? "เปลี่ยนเป็น Warmup Set แล้ว"
                    : "เปลี่ยนเป็น Working Set แล้ว",
                Severity.Success);
        }
        catch (Exception ex)
        {
            // คืนค่า UI หากบันทึกไม่สำเร็จ
            set.IsWarmup = !set.IsWarmup;
            set.SetType = set.IsWarmup
                ? "Warmup"
                : "Working";

            Snackbar.Add(
                $"เปลี่ยนประเภท Set ไม่สำเร็จ: {ex.Message}",
                Severity.Error);
        }
    }

    private void CalculateProgress()
    {
        if (_session is null)
        {
            _totalSets = 0;
            _completedSets = 0;
            _progressPercent = 0;
            return;
        }

        _totalSets = _session.Exercises
            .SelectMany(x => x.Sets)
            .Count();

        _completedSets = _session.Exercises
            .SelectMany(x => x.Sets)
            .Count(x => x.IsCompleted);

        _progressPercent = _totalSets == 0
            ? 0
            : Math.Round(
                (double)_completedSets / _totalSets * 100,
                0);
    }
    private void GoToSummary()
    {
        NavigationManager.NavigateTo(
            $"/workout/summary/{WorkoutSessionId}");
    }
    private decimal CalculateCurrentVolume()
    {
        if (_session is null)
        {
            return 0;
        }

        return _session.Exercises
            .SelectMany(x => x.Sets)
            .Where(x => x.IsCompleted && !x.IsSkipped)
            .Sum(x =>
                (x.ActualWeightKg ?? 0)
                * (x.ActualReps ?? 0));
    }
}