@page "/login"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavigationManager

<PageTitle>Login | FitAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small"
              Class="py-8">

    <MudPaper Elevation="2"
              Class="pa-6 login-card">

        <MudText Typo="Typo.h4"
                 Align="Align.Center"
                 Class="mb-2">
            FitAI
        </MudText>

        <MudText Typo="Typo.body1"
                 Color="Color.Secondary"
                 Align="Align.Center"
                 Class="mb-5">
            Sign in to continue your training
        </MudText>
        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <MudAlert Severity="Severity.Success"
                      Class="mb-4">
                @_successMessage
            </MudAlert>
        }
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error"
                      Class="mb-4">
                @_errorMessage
            </MudAlert>
        }

        <form method="post"
              action="/account/login">

            <AntiforgeryToken />

            <input type="hidden"
                   name="ReturnUrl"
                   value="@_returnUrl" />

            <input type="email"
                   name="Email"
                   required />

            <input type="password"
                   name="Password"
                   required />

            <button type="submit">
                Login
            </button>
        </form>

    </MudPaper>
    <MudDivider Class="my-5" />

    <div class="text-center">
        <MudText Typo="Typo.body2"
                 Color="Color.Secondary">
            ยังไม่มีบัญชี?
        </MudText>

        <MudButton Href="/register"
                   Variant="Variant.Text"
                   Color="Color.Primary">
            Create account
        </MudButton>
    </div>
</MudContainer>

@code {
    private string _returnUrl = "/";
    private string? _errorMessage;
    private string? _successMessage;
    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(
            NavigationManager.Uri);

        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue(
                "returnUrl",
                out var returnUrl)
            && !string.IsNullOrWhiteSpace(returnUrl))
        {
            _returnUrl = returnUrl.ToString();
        }

        if (!query.TryGetValue("error", out var error))
        {
            return;
        }

        _errorMessage = error.ToString() switch
        {
            "invalid_credentials" =>
                "อีเมลหรือรหัสผ่านไม่ถูกต้อง",

            "missing_credentials" =>
                "กรุณากรอกอีเมลและรหัสผ่าน",

            _ => "ไม่สามารถเข้าสู่ระบบได้"
        };
        if (query.TryGetValue(
        "confirmed",
        out var confirmed)
    && string.Equals(
        confirmed.ToString(),
        "true",
        StringComparison.OrdinalIgnoreCase))
        {
            _successMessage =
                "ยืนยันอีเมลเรียบร้อยแล้ว กรุณาเข้าสู่ระบบ";
        }
    }
}